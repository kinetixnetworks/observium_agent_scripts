#!/bin/bash
#
# Observium Unix Agent script for Galera cluster monitoring
#
# Install path: /usr/lib/observium_agent/local/galera   (chmod 0755)
#
# Output is positional — one value per line, parsed by position in the
# polling include. Order MUST match the explode() in galera.inc.php.
#
# Field order (1-indexed):
#   1.  mysql_reachable        0 or 1
#   2.  cluster_size           int
#   3.  cluster_status         1=Primary, 0=non-Primary, -1=Disconnected, -2=Unknown
#   4.  local_state            0-6 (4 = Synced)
#   5.  ready                  1=ON, 0=OFF, -1=unknown
#   6.  connected              1=ON, 0=OFF, -1=unknown
#   7.  recv_queue_avg         float
#   8.  send_queue_avg         float
#   9.  flow_paused            float, 0.0-1.0
#  10.  cert_failures          counter
#  11.  bf_aborts              counter
#  12.  received               counter (writesets received from cluster)
#  13.  received_bytes         counter
#  14.  replicated             counter (writesets sent to cluster)
#  15.  replicated_bytes       counter
#
# Requires /etc/galera_monitor.cnf:
#   [client]
#   user=monitor
#   password=CHANGEME
#   host=127.0.0.1
#
# (chmod 0440, owned by whichever user xinetd runs the agent as)
#
# MySQL grants:
#   CREATE USER 'monitor'@'127.0.0.1' IDENTIFIED BY 'CHANGEME';
#   GRANT PROCESS ON *.* TO 'monitor'@'127.0.0.1';
#

DEFAULTS_FILE="/etc/galera_monitor.cnf"

echo "<<<app-galera>>>"

# If MySQL is unreachable, emit a "node down" record. Every numeric field is U
# (RRD's unknown marker) except mysql_reachable=0 which is the canary the
# polling side keys off.
if ! out=$(mysql --defaults-extra-file="$DEFAULTS_FILE" \
                 --connect-timeout=3 \
                 -BNe "SHOW GLOBAL STATUS LIKE 'wsrep_%'" 2>/dev/null); then
    printf '0\nU\nU\nU\nU\nU\nU\nU\nU\nU\nU\nU\nU\nU\nU\n'
    exit 0
fi

get() { awk -v k="$1" '$1 == k { print $2; exit }' <<< "$out"; }

map_status() {
    case "$1" in
        Primary)                 echo 1 ;;
        non-Primary|Non-Primary) echo 0 ;;
        Disconnected)            echo -1 ;;
        *)                       echo -2 ;;
    esac
}

map_on_off() {
    case "$1" in
        ON|on|1)   echo 1 ;;
        OFF|off|0) echo 0 ;;
        *)         echo -1 ;;
    esac
}

# Order matters — keep aligned with the field-order comment above and the
# polling include's list() destructuring.
echo 1
echo "$(get wsrep_cluster_size)"
echo "$(map_status   "$(get wsrep_cluster_status)")"
echo "$(get wsrep_local_state)"
echo "$(map_on_off   "$(get wsrep_ready)")"
echo "$(map_on_off   "$(get wsrep_connected)")"
echo "$(get wsrep_local_recv_queue_avg)"
echo "$(get wsrep_local_send_queue_avg)"
echo "$(get wsrep_flow_control_paused)"
echo "$(get wsrep_local_cert_failures)"
echo "$(get wsrep_local_bf_aborts)"
echo "$(get wsrep_received)"
echo "$(get wsrep_received_bytes)"
echo "$(get wsrep_replicated)"
echo "$(get wsrep_replicated_bytes)"
